{
  "dashboard": {
    "title": "AI训练平台监控",
    "tags": ["ai", "training", "monitoring"],
    "timezone": "Asia/Shanghai",
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "系统资源使用",
        "type": "stat",
        "targets": [
          {
            "expr": "ai_system_memory_percent",
            "legendFormat": "内存使用率"
          },
          {
            "expr": "ai_system_cpu_percent",
            "legendFormat": "CPU使用率"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 70},
                {"color": "red", "value": 85}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "加载模型数",
        "type": "stat",
        "targets": [
          {
            "expr": "ai_loaded_models_count",
            "legendFormat": "模型数"
          }
        ],
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "活跃项目数",
        "type": "stat",
        "targets": [
          {
            "expr": "ai_active_projects",
            "legendFormat": "项目数"
          }
        ],
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0}
      },
      {
        "id": 4,
        "title": "预测请求速率",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(ai_prediction_total[1m])",
            "legendFormat": "{{model_type}} - {{status}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 5,
        "title": "预测延迟 (P95)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(ai_prediction_latency_seconds_bucket[5m]))",
            "legendFormat": "{{model_type}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 6,
        "title": "预测置信度分布",
        "type": "heatmap",
        "targets": [
          {
            "expr": "rate(ai_prediction_confidence_bucket[5m])",
            "legendFormat": "{{model_type}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "id": 7,
        "title": "训练任务统计",
        "type": "graph",
        "targets": [
          {
            "expr": "increase(ai_training_total[1h])",
            "legendFormat": "{{task_type}} - {{status}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
      },
      {
        "id": 8,
        "title": "模型准确率",
        "type": "graph",
        "targets": [
          {
            "expr": "ai_model_accuracy",
            "legendFormat": "{{model_id}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1
          }
        },
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24}
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    }
  }
}
